{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 104857600,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss zzz} [{Level:u3}] {SourceContext} {Properties:j} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "Properties": {
      "Application": "HR-AUTOMATION-API"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:5173",
      "http://192.168.15.86:3001"
    ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "Access-Control-Allow-Origin", "Accept-Language", "X-Time-Zone", "X-Requested-With", "X-Signalr-User-Agent", "X-Forwarded-For", "X-Forwarded-Proto" ],
    "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
    "ExposedHeaders": [ "Content-Disposition" ]
  },

  "ConnectionConfigurations": {
    "SqlServerConnection": {
      "ConnectionString": "Server=192.168.15.21\\ENG_DEV,6064;Database=HR_Automation;User Id=Fmartinez;Password=DFR.K8!X46XdsHCuXfEot-eY.;Encrypt=True;TrustServerCertificate=True;",
      "Timeout": 120
    }
  },
  "Redis": {
    "ConnectionString": "host.docker.internal:6379",
    "Expiration": {
      "Short": 300000,
      "Default": 1800000,
      "Long": 43200000
    }
  }
}